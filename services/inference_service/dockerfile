FROM ghcr.io/astral-sh/uv:python3.12-bookworm-slim

# Install uv for fast dependency management
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    UV_SYSTEM_PYTHON=1

WORKDIR /inference_service

# Install dependencies FIRST (caching layer)
# Copy service-specific pyproject.toml
COPY pyproject.toml uv.lock ./

# No lock file yet, so perform sync without frozen
RUN uv sync --frozen --no-dev --group inference

RUN apt-get update \
    && apt-get install -y --no-install-recommends build-essential \
    && rm -rf /var/lib/apt/lists/*

# Copy application code using paths relative to build context (project root)
COPY services/inference_service/src/ src/
COPY services/inference_service/config/ config/

# Set Environment for imports
# Add /inference_service (for config) and /inference_service/src (for preprocessor) to PYTHONPATH
# ENV PYTHONPATH="/inference_service:/inference_service/:$PYTHONPATH"
# ENV PATH="/inference_service/.venv/bin:$PATH"

# Default Command
CMD ["uv", "run", "-m", "src.app"]
# CMD ["uvicorn", "src.app:app", "--host", "0.0.0.0", "--port", "8000"]

