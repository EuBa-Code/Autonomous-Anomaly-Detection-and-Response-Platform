# Start from the same Python base image
FROM ghcr.io/astral-sh/uv:python3.12-bookworm-slim

# 1. Install Java (Required for PySpark)
# PySpark runs on the JVM, so we need openjdk-17-jre
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
    openjdk-17-jre-headless \
    procps && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Set JAVA_HOME environment variable (good practice for Spark)
ENV JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64

WORKDIR /hist_ingestion

# 2. Copy dependency definitions
COPY pyproject.toml uv.lock ./

# 3. Install dependencies (Make sure 'pyspark' is in your pyproject.toml)
RUN uv sync --frozen --no-dev --group hist_ingestion

# 4. Copy source code
COPY services/historical_ingestion_service/src ./src/
COPY services/historical_ingestion_service/config ./config/

ENV PYTHONPATH=/hist_ingestion/src:$PYTHONPATH

# 5. Run the script
CMD ["uv", "run", "python", "src/generate_preprocessor.py"]