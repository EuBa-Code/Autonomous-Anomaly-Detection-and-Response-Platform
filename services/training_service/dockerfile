FROM ghcr.io/astral-sh/uv:python3.12-bookworm-slim

WORKDIR /training_service

COPY services/training_service/pyproject.toml services/training_service/uv.lock* ./

RUN uv sync --frozen --no-dev --group training

COPY services/training_service/src ./src/
COPY services/training_service/config ./config/

RUN mkdir -p ./data/raw \
            ./data/processed \
            ./models \
            ./metrics \
            ./logs \
            /outputs

ENV PYTHONPATH="/training_service:/training/src"
ENV PATH="/training_service/.venv/bin:$PATH"

CMD ["uv", "run", "-m", "src.train"]