FROM ghcr.io/astral-sh/uv:python3.12-bookworm-slim

WORKDIR /training

COPY pyproject.toml uv.lock ./

RUN uv sync --frozen --no-dev --group training_ml

COPY services/training_service/src/ ./src/
COPY services/training_service/config/ ./config/

RUN mkdir -p /training/data/raw \
    /training/data/processed \
    /training/models \
    /training/metrics \
    /training/logs

ENV PYTHONPATH="/training:/training/src"

CMD ["python", "src/train.py"]