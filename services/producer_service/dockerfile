FROM ghcr.io/astral-sh/uv:python3.12-bookworm-slim

WORKDIR /producer

COPY pyproject.toml uv.lock ./

RUN uv sync --no-dev --group ingestion

COPY services/producer_service/src ./src/
COPY services/producer_service/config ./config/

ENV PYTHONPATH="/producer"
# Activate the venv so 'python' resolves to the venv interpreter
ENV PATH="/producer/.venv/bin:$PATH"

CMD ["python", "src/producer.py"]
